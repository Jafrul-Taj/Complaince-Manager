<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <!-- Required for ${aspnet-request-*} layout renderers -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <!--
    async="true" wraps all targets in an AsyncWrapper automatically.
    Log calls return immediately; writes happen on a background thread.
  -->
  <targets async="true">

    <!--
      Main application log — all levels from Information up.
      Rolls daily; keeps 30 days of history.
      Layout: timestamp | LEVEL | ClassName | message (+exception with full stack trace)
    -->
    <target xsi:type="File"
            name="appFile"
            fileName="${basedir}/logs/app-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message:withexception=true}"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveDays="30"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!--
      Error-only log — Warning and above only.
      Includes HTTP method + URL for request context.
      Kept for 90 days so incidents can be investigated after the fact.
    -->
    <target xsi:type="File"
            name="errorFile"
            fileName="${basedir}/logs/errors-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${aspnet-request-method} ${aspnet-request-url} | ${message:withexception=true}"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveDays="90"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8" />

    <!--
      Colored console — Debug and above.
      Short format suitable for reading during development.
    -->
    <target xsi:type="ColoredConsole"
            name="console"
            useDefaultRowHighlightingRules="false"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=message}">
      <highlight-row condition="level == LogLevel.Fatal" foregroundColor="Red"     backgroundColor="White" />
      <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
      <highlight-row condition="level == LogLevel.Warn"  foregroundColor="Yellow" />
      <highlight-row condition="level == LogLevel.Info"  foregroundColor="Cyan" />
      <highlight-row condition="level == LogLevel.Debug" foregroundColor="Gray" />
      <highlight-row condition="level == LogLevel.Trace" foregroundColor="DarkGray" />
    </target>

  </targets>

  <rules>
    <!--
      Suppress high-frequency framework noise (EF query plans, HTTP handler
      lifecycle, etc.).  "final='true'" means nothing else sees these messages.
    -->
    <logger name="Microsoft.AspNetCore.*"        maxlevel="Info" final="true" />
    <logger name="Microsoft.EntityFrameworkCore.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*"             maxlevel="Info" final="true" />
    <logger name="Microsoft.*"                   maxlevel="Info" final="true" />

    <!--
      Application rules — apply to everything that wasn't suppressed above.
      Three separate writeTo entries so each target gets only the levels it cares about.
    -->
    <logger name="*" minlevel="Debug"       writeTo="console" />
    <logger name="*" minlevel="Information" writeTo="appFile" />
    <logger name="*" minlevel="Warn"        writeTo="errorFile" />
  </rules>

</nlog>
